{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "MW101_TESTS": "ON",
        "MW_BUILD_PLUGIN": "OFF",
        "MW_BUILD_CLAP": "OFF",
        "MW_BUILD_LV2": "OFF"
      },
      "environment": {
        "CPM_SOURCE_CACHE": "$env{HOME}/.cache/CPM"
      }
    },
    {
      "name": "default",
      "inherits": "base",
      "displayName": "Default (RelWithDebInfo, FP-disciplined)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
    },
    {
      "name": "debug",
      "inherits": "base",
      "displayName": "Debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "asan",
      "inherits": "debug",
      "displayName": "AddressSanitizer",
      "cacheVariables": { "MW_ENABLE_ASAN": "ON" }
    },
    {
      "name": "ubsan",
      "inherits": "debug",
      "displayName": "UndefinedBehaviorSanitizer",
      "cacheVariables": { "MW_ENABLE_UBSAN": "ON" }
    },
    {
      "name": "tsan",
      "inherits": "debug",
      "displayName": "ThreadSanitizer",
      "cacheVariables": { "MW_ENABLE_TSAN": "ON" }
    },
    {
      "name": "macos-arm64",
      "inherits": "default",
      "displayName": "macOS arm64 (reference/bless)",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "MWAUDIO_FORMATS": "VST3;AU;CLAP;Standalone",
        "MW_BUILD_CLAP": "ON"
      }
    },
    {
      "name": "linux-x64",
      "inherits": "default",
      "displayName": "Linux x64 (co-required hard gate)",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
      "cacheVariables": {
        "MWAUDIO_FORMATS": "VST3;CLAP;Standalone;LV2",
        "MW_BUILD_CLAP": "ON",
        "MW_BUILD_LV2": "ON"
      }
    },
    {
      "name": "windows-x64",
      "inherits": "default",
      "displayName": "Windows x64 (goal tier)",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": {
        "MWAUDIO_FORMATS": "VST3;CLAP;Standalone",
        "MW_BUILD_CLAP": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "default",     "configurePreset": "default" },
    { "name": "debug",       "configurePreset": "debug" },
    { "name": "release",     "configurePreset": "release" },
    { "name": "asan",        "configurePreset": "asan" },
    { "name": "ubsan",       "configurePreset": "ubsan" },
    { "name": "tsan",        "configurePreset": "tsan" },
    { "name": "macos-arm64", "configurePreset": "macos-arm64" },
    { "name": "linux-x64",   "configurePreset": "linux-x64" },
    { "name": "windows-x64", "configurePreset": "windows-x64" }
  ],
  "testPresets": [
    {
      "name": "test-base",
      "hidden": true,
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false, "jobs": 4 }
    },
    { "name": "default",     "inherits": "test-base", "configurePreset": "default" },
    { "name": "debug",       "inherits": "test-base", "configurePreset": "debug" },
    { "name": "release",     "inherits": "test-base", "configurePreset": "release" },
    { "name": "asan",        "inherits": "test-base", "configurePreset": "asan" },
    { "name": "ubsan",       "inherits": "test-base", "configurePreset": "ubsan" },
    { "name": "tsan",        "inherits": "test-base", "configurePreset": "tsan" },
    { "name": "macos-arm64", "inherits": "test-base", "configurePreset": "macos-arm64" },
    { "name": "linux-x64",   "inherits": "test-base", "configurePreset": "linux-x64" },
    { "name": "windows-x64", "inherits": "test-base", "configurePreset": "windows-x64" }
  ]
}
