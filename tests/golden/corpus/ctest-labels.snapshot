# Checked-in subsystem-tag snapshot (docs/design/11 §8.4; ADR-013 C3). A
# deleted/renamed labelled suite shows as a failing diff against this file, not
# silence. Updating it is a reviewed change. Regenerate with:
#   <test-bin> --list-tags   (then take the [bracketed] tags, sorted + deduped)
[blockcontext]
[cal]
[calibration]
[capabilities]
[core]
[engineversion]
